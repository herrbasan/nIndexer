{
  "service": {
    "host": "localhost",
    "port": 3666,
    "cors": false
  },
  "storage": {
    "dataDir": "./data/codebases",
    "trashDir": "./data/trash"
  },
  "logs": {
    "dir": "./logs",
    "retentionDays": 7
  },
  "indexing": {
    "embeddingDimension": 768,
    "maxFileSize": 1048576,
    "ignorePatterns": [
      "**/node_modules/**",
      "**/.git/**",
      "**/dist/**",
      "**/build/**",
      "**/.vscode/**",
      "**/.idea/**",
      "**/coverage/**",
      "**/.pytest_cache/**",
      "**/__pycache__/**",
      "**/.venv/**",
      "**/venv/**",
      "**/target/**",
      "**/bin/**",
      "**/obj/**",
      "**/Debug/**",
      "**/Release/**",
      "*.log",
      "*.tmp",
      "*.lock",
      "package-lock.json",
      "yarn.lock",
      "*.pyc",
      "*.map",
      "**/*.min.js",
      "**/*.min.css",
      "**/*.d.ts",
      "*.png",
      "*.jpg",
      "*.jpeg",
      "*.gif",
      "*.bmp",
      "*.ico",
      "*.svg",
      "*.pdf",
      "*.doc",
      "*.docx",
      "**/data/codebases/**",
      "**/data/trash/**",
      "**/logs/**"
    ],
    "batchSize": 25,
    "indexBatchSize": 50
  },
  "maintenance": {
    "enabled": true,
    "intervalMs": 900000,
    "autoRefresh": true
  },
  "discovery": {
    "roots": [],
    "scanIntervalMs": 3600000
  },
  "codebases": {},
  "llama": {
    "port": 42718,
    "modelPath": "bin/llama/models/jina-embeddings-v2-base-code-Q5_K_M.gguf",
    "ctxSize": 8192,
    "concurrencyLimit": 50
  },
  "llm": {
    "provider": "local",
    "maxConcurrentRequests": 100,
    "remoteFallback": null
  }
}
